alias ga='git add'
ga.pcmd() {
    if [ -z "$1" ]; then
        echo "error: commit message required." >&2
        echo "usage: ga.p <message>" >&2
        return 1
    fi

    git add . && git commit -m "$1" && git push
}
alias ga.p='ga.pcmd'
