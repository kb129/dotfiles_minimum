alias cdd='cd $(ghq root)/$(ghq list | fzf)'
tm() {
  if [ -n "$TMUX" ]; then
    echo "Already in tmux ($TMUX)"
    return
  fi

  local name=${1:-main}
  if tmux has-session -t "$name" 2>/dev/null; then
    tmux attach -t "$name"
  else
    tmux new -s "$name"
  fi
}
alias t=tm
